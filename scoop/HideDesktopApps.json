{
    "version": "1.2.1",
    "description": "System tray app to hide/show desktop icons, taskbar, and all windows via configurable hotkeys. Rust-native, single binary.",
    "homepage": "https://github.com/Londopy/HideDesktopApps",
    "license": "MIT",
    "url": "https://github.com/Londopy/HideDesktopApps/releases/download/v1.2.1/HideDesktopApps-v1.2.1-portable.zip",
    "hash": "0a6e4a1b3fafd66642df2f91dc0ce621daee56b1cbd1ea5da037206d422b7d75",
    "extract_dir": "HideDesktopApps",
    "architecture": {
        "64bit": {
            "bin": "x64\\HideDesktopApps.exe",
            "shortcuts": [
                ["x64\\HideDesktopApps.exe", "HideDesktopApps"]
            ]
        },
        "32bit": {
            "bin": "x86\\HideDesktopApps.exe",
            "shortcuts": [
                ["x86\\HideDesktopApps.exe", "HideDesktopApps"]
            ]
        },
        "arm64": {
            "bin": "arm64\\HideDesktopApps.exe",
            "shortcuts": [
                ["arm64\\HideDesktopApps.exe", "HideDesktopApps"]
            ]
        }
    },
    "persist": [
        "x64\\config.toml",
        "x86\\config.toml",
        "arm64\\config.toml"
    ],
    "pre_install": "@('x64','x86','arm64') | ForEach-Object { $sub = Join-Path $dir $_; if (Test-Path $sub) { $marker = Join-Path $sub 'portable'; if (!(Test-Path $marker)) { New-Item -ItemType File -Path $marker | Out-Null } } }",
    "checkver": {
        "github": "https://github.com/Londopy/HideDesktopApps"
    },
    "autoupdate": {
        "url": "https://github.com/Londopy/HideDesktopApps/releases/download/v$version/HideDesktopApps-v$version-portable.zip",
        "hash": {
            "url": "https://github.com/Londopy/HideDesktopApps/releases/download/v$version/HideDesktopApps-v$version-portable.zip.sha256"
        }
    }
}
